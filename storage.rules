rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user is an admin via Firestore
    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Submissions: Match /submissions/UID/category/filename
    match /submissions/{ownerId}/{allPaths=**} {
      // Allow read/write if the user's UID matches the ownerId in the path
      allow read, write: if isSignedIn() && request.auth.uid == ownerId;

      // Also allow admins full access
      allow read, write: if isAdmin();
    }

    // Public resources
    match /resources/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Portal documents
    match /documents/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
